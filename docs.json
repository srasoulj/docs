{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "sequoia",
  "name": "Rumizi",
  "description": "Help center for Rumizi vendors and diners.",
  "colors": {
    "primary": "#16A34A",
    "light": "#22C55E",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "For vendors",
        "groups": [
          {
            "group": "Get started",
            "pages": [
              "vendors/index",
              "vendors/first-menu"
            ]
          },
          {
            "group": "Your menu",
            "pages": [
              "vendors/menu/upload",
              "vendors/menu/editing",
              "vendors/menu/publish",
              "vendors/menu/scheduling",
              "vendors/menu/translations",
              "vendors/menu/tags",
              "vendors/menu/cross-sell",
              "vendors/menu/availability"
            ]
          },
          {
            "group": "Media",
            "pages": [
              "vendors/media/gallery",
              "vendors/media/ai-images"
            ]
          },
          {
            "group": "Your venue page",
            "pages": [
              "vendors/venue/landing-page",
              "vendors/venue/theme",
              "vendors/venue/languages"
            ]
          },
          {
            "group": "AI assistant",
            "pages": [
              "vendors/assistant/overview"
            ]
          },
          {
            "group": "Billing",
            "pages": [
              "vendors/billing/subscription"
            ]
          },
          {
            "group": "Help",
            "pages": [
              "vendors/faq"
            ]
          }
        ]
      },
      {
        "tab": "For diners",
        "groups": [
          {
            "group": "Using Rumizi",
            "pages": [
              "diners/index",
              "diners/scan-and-browse",
              "diners/accounts",
              "diners/order-together",
              "diners/menu-assistant",
              "diners/languages"
            ]
          },
          {
            "group": "Help",
            "pages": [
              "diners/faq"
            ]
          }
        ]
      },
      {
        "tab": "Reference",
        "groups": [
          {
            "group": "Reference",
            "pages": [
              "reference/glossary",
              "reference/status"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Rumizi site",
          "href": "https://rumizi.com",
          "icon": "house"
        },
        {
          "anchor": "Vendor dashboard",
          "href": "https://rumizi.com/login",
          "icon": "user"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:hi@rumizi.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open Rumizi",
      "href": "https://rumizi.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "fonts": {
    "family": "Lato"
  },
  "footer": {
    "socials": {
      "website": "https://rumizi.com"
    }
  },
  "icons": {
    "library": "lucide"
  },
  "seo": {
    "indexing": "all"
  },
  "metadata": {
    "timestamp": true
  },
  "interaction": {
    "drilldown": false
  }
}
